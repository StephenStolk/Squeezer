# Copy to .env and adjust as needed. All vars are prefixed SQUEEZER_.

SQUEEZER_PROXY_HOST=127.0.0.1
SQUEEZER_PROXY_PORT=8787

SQUEEZER_ANTHROPIC_UPSTREAM=https://api.anthropic.com
SQUEEZER_OPENAI_UPSTREAM=https://api.openai.com
SQUEEZER_OPENROUTER_UPSTREAM=https://openrouter.ai/api

SQUEEZER_DASHBOARD_PORT=8788
SQUEEZER_DASHBOARD_ENABLED=true

SQUEEZER_LOG_LEVEL=INFO

# Aggressiveness knobs
SQUEEZER_LSH_SIMILARITY_THRESHOLD=0.85
SQUEEZER_TEMPORAL_RECENT_TURNS=2
SQUEEZER_TEMPORAL_PARTIAL_TURNS=8
SQUEEZER_CCR_TOKEN_THRESHOLD=2000
SQUEEZER_JSON_MAX_DEPTH=4

# Feature toggles (true/false)
SQUEEZER_ENABLE_AST_COMPACTOR=true
SQUEEZER_ENABLE_CALL_GRAPH_PRUNER=true
SQUEEZER_ENABLE_JSON_CRUSHER=true
SQUEEZER_ENABLE_LSH_DEDUPLICATOR=true
SQUEEZER_ENABLE_SHELL_SANDBOX=true
SQUEEZER_ENABLE_LINGUISTIC_MINIFIER=true
SQUEEZER_ENABLE_TEMPORAL_DECAY=true
SQUEEZER_ENABLE_PII_SCRUBBER=true
SQUEEZER_ENABLE_CACHE_ALIGNER=true
SQUEEZER_ENABLE_CCR=true
